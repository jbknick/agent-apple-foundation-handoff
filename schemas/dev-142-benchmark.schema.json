{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-142-benchmark.schema.json",
  "$comment": "Draft 2020-12 covers structure. The closed x-dev142 vocabulary, enforced by the repository-local semantic evaluator and Python validator, covers cross-value invariants.",
  "x-dev142-constraints": {
    "uniqueBy": [
      {"array": "/cases", "keys": ["id"]},
      {"array": "/arms", "keys": ["id"]},
      {"array": "/pairs", "keys": ["id"]}
    ]
  },
  "oneOf": [{"$ref": "#/$defs/corpus"}, {"$ref": "#/$defs/evidence"}],
  "$defs": {
    "expected": {
      "type": "object", "additionalProperties": false,
      "required": ["exitStatus", "interrupted", "warningCount", "requiredDiagnosticIDs", "failedTestIDs"],
      "properties": {
        "exitStatus": {"type": ["integer", "null"], "minimum": 0, "maximum": 255}, "interrupted": {"type": "boolean"}, "warningCount": {"type": "integer", "minimum": 0},
        "requiredDiagnosticIDs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "failedTestIDs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "allOf": [{"if": {"properties": {"interrupted": {"const": false}}}, "then": {"properties": {"exitStatus": {"type": "integer"}}}}]
    },
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "commandClass", "commandForm", "classification", "renderedSha256", "expected"],
      "properties": {
        "id": {"type": "string", "minLength": 1}, "commandClass": {"type": "string", "enum": ["test", "build", "typecheck", "lint"]}, "commandForm": {"type": "string", "minLength": 1},
        "classification": {"type": "string", "enum": ["C0", "C1"]}, "renderedSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "expected": {"$ref": "#/$defs/expected"}
      }
    },
    "corpus": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "policyVersion", "kind", "corpusVersion", "corpusSha256", "cases"],
      "properties": {
        "schemaVersion": {"const": 1}, "policyVersion": {"const": "diagnostic-condensation-v1"}, "kind": {"const": "corpus"}, "corpusVersion": {"type": "string", "minLength": 1},
        "corpusSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "cases": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case"}, "uniqueItems": true}
      }
    },
    "arm": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "pairID", "arm", "provider", "inputTokens", "cachedInputTokens", "outputTokens", "reasoningTokens", "totalParentModelTokens", "parentTurns", "appleAttempts", "replacements", "declines", "fallbacks", "latencyMilliseconds", "correct"],
      "properties": {
        "id": {"type": "string", "minLength": 1}, "pairID": {"type": "string", "minLength": 1}, "arm": {"type": "string", "enum": ["pluginOff", "pluginOn"]}, "provider": {"type": "string", "enum": ["openai-responses-usage-v1", "anthropic-messages-usage-v1"]},
        "inputTokens": {"type": ["integer", "null"], "minimum": 0}, "cachedInputTokens": {"type": ["integer", "null"], "minimum": 0}, "outputTokens": {"type": ["integer", "null"], "minimum": 0}, "reasoningTokens": {"type": ["integer", "null"], "minimum": 0},
        "totalParentModelTokens": {"type": ["integer", "null"], "minimum": 0}, "parentTurns": {"type": ["integer", "null"], "minimum": 0}, "appleAttempts": {"type": ["integer", "null"], "minimum": 0}, "replacements": {"type": ["integer", "null"], "minimum": 0},
        "declines": {"type": ["integer", "null"], "minimum": 0}, "fallbacks": {"type": ["integer", "null"], "minimum": 0}, "latencyMilliseconds": {"type": ["integer", "null"], "minimum": 0}, "correct": {"type": ["boolean", "null"]}
      },
      "allOf": [{"if": {"properties": {"arm": {"const": "pluginOff"}}}, "then": {"properties": {"appleAttempts": {"enum": [0, null]}, "replacements": {"enum": [0, null]}}}}]
    },
    "pair": {
      "type": "object", "additionalProperties": false, "required": ["id", "status", "reduction"],
      "properties": {"id": {"type": "string", "minLength": 1}, "status": {"type": "string", "enum": ["valid", "blocked"]}, "reduction": {"type": ["number", "null"], "minimum": -1, "maximum": 1}},
      "allOf": [{"if": {"properties": {"status": {"const": "blocked"}}}, "then": {"properties": {"reduction": {"const": null}}}}]
    },
    "release": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "validRequiredPairs", "blockedRequiredPairs", "medianReduction", "correctnessRegressions", "additionalParentModelTurns"],
      "properties": {"status": {"type": "string", "enum": ["pass", "fail", "blocked"]}, "validRequiredPairs": {"type": "integer", "minimum": 0}, "blockedRequiredPairs": {"type": "integer", "minimum": 0}, "medianReduction": {"type": ["number", "null"], "minimum": -1, "maximum": 1}, "correctnessRegressions": {"type": "integer", "minimum": 0}, "additionalParentModelTurns": {"type": "integer", "minimum": 0}}
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "policyVersion", "kind", "arms", "pairs", "release"],
      "properties": {"schemaVersion": {"const": 1}, "policyVersion": {"const": "diagnostic-condensation-v1"}, "kind": {"const": "evidence"}, "arms": {"type": "array", "items": {"$ref": "#/$defs/arm"}, "uniqueItems": true}, "pairs": {"type": "array", "items": {"$ref": "#/$defs/pair"}, "uniqueItems": true}, "release": {"$ref": "#/$defs/release"}}
    }
  }
}
