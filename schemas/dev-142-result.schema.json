{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-142-result.schema.json",
  "$comment": "Draft 2020-12 covers structure. The closed x-dev142 vocabulary, enforced by the repository-local semantic evaluator and Python validator, covers cross-value invariants.",
  "x-dev142-constraints": {
    "uniqueBy": [{"array": "/condensation/diagnostics", "keys": ["severity", "code", "message", "file", "line", "column", "failedTestID"]}],
    "repoRelativePath": [{"array": "/condensation/diagnostics", "when": {}, "field": "file", "nullable": true}],
    "lessThanOrEqual": [{"left": "/condensation/omittedWarningCount", "right": "/condensation/warningCount"}],
    "warningAccounting": [{"array": "/condensation/diagnostics", "severityField": "severity", "warningValue": "warning", "omitted": "/condensation/omittedWarningCount", "total": "/condensation/warningCount"}]
  },
  "oneOf": [{"$ref": "#/$defs/applied"}, {"$ref": "#/$defs/nonApplied"}],
  "$defs": {
    "diagnostic": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "severity", "code", "message", "file", "line", "column", "failedTestID"],
      "properties": {
        "id": {"type": "string", "minLength": 1}, "severity": {"type": "string", "enum": ["fatal", "error", "warning", "info"]},
        "code": {"type": "string"}, "message": {"type": "string", "minLength": 1}, "file": {"type": ["string", "null"]},
        "line": {"type": ["integer", "null"], "minimum": 1}, "column": {"type": ["integer", "null"], "minimum": 1},
        "failedTestID": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "condensation": {
      "type": "object", "additionalProperties": false,
      "required": ["commandOutcome", "summary", "summaryFacts", "diagnostics", "warningCount", "omittedWarningCount", "nextAction", "completionFacts"],
      "properties": {
        "commandOutcome": {"type": "string", "enum": ["success", "failure", "interrupted"]},
        "summary": {"type": "string", "minLength": 1}, "diagnostics": {"type": "array", "items": {"$ref": "#/$defs/diagnostic"}},
        "summaryFacts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "warningCount": {"type": "integer", "minimum": 0}, "omittedWarningCount": {"type": "integer", "minimum": 0},
        "nextAction": {"type": "string", "minLength": 1},
        "completionFacts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "applied": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "policyVersion", "callID", "toolName", "toolVersion", "stateVersion", "action", "commandClass", "originalResultType", "originalResultDigest", "outcome", "exitStatus", "interrupted", "resultType", "condensation"],
      "properties": {
        "schemaVersion": {"const": 1}, "policyVersion": {"const": "diagnostic-condensation-v1"},
        "callID": {"type": "string", "minLength": 1}, "toolName": {"const": "Bash"}, "toolVersion": {"type": "string", "minLength": 1}, "stateVersion": {"type": "string", "minLength": 1},
        "action": {"const": "condense_diagnostic_output"}, "commandClass": {"type": "string", "enum": ["test", "build", "typecheck", "lint"]}, "originalResultType": {"type": "string", "minLength": 1},
        "originalResultDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "outcome": {"const": "applied"}, "exitStatus": {"type": ["integer", "null"], "minimum": 0, "maximum": 255},
        "interrupted": {"type": "boolean"}, "resultType": {"const": "diagnostic_condensation"}, "condensation": {"$ref": "#/$defs/condensation"}
      },
      "allOf": [{"if": {"properties": {"interrupted": {"const": false}}}, "then": {"properties": {"exitStatus": {"type": "integer"}}}}]
    },
    "nonApplied": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "policyVersion", "callID", "toolName", "toolVersion", "stateVersion", "action", "commandClass", "originalResultType", "originalResultDigest", "outcome", "exitStatus", "interrupted", "reasonCode"],
      "properties": {
        "schemaVersion": {"const": 1}, "policyVersion": {"const": "diagnostic-condensation-v1"},
        "callID": {"type": "string", "minLength": 1}, "toolName": {"const": "Bash"}, "toolVersion": {"type": "string", "minLength": 1}, "stateVersion": {"type": "string", "minLength": 1},
        "action": {"const": "condense_diagnostic_output"}, "commandClass": {"type": "string", "enum": ["test", "build", "typecheck", "lint"]}, "originalResultType": {"type": "string", "minLength": 1},
        "originalResultDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "outcome": {"type": "string", "enum": ["declined", "fail"]}, "exitStatus": {"type": ["integer", "null"], "minimum": 0, "maximum": 255},
        "interrupted": {"type": "boolean"}, "reasonCode": {"type": "string", "enum": ["tool_not_allowed", "command_not_allowed", "compound_command", "data_policy_denied", "input_below_minimum", "input_above_maximum", "apple_unavailable", "locale_unsupported", "context_budget_exceeded", "generation_declined", "cancelled", "deadline_exceeded", "invalid_response", "insufficient_realized_savings", "host_replacement_unavailable", "host_replacement_failed", "contract_invariant_failed"]}
      },
      "allOf": [{"if": {"properties": {"interrupted": {"const": false}}}, "then": {"properties": {"exitStatus": {"type": "integer"}}}}]
    }
  }
}
