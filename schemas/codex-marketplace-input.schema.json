{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "interface", "plugins"],
  "properties": {
    "name": {
      "const": "agent-apple-foundation-handoff"
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayName"],
      "properties": {
        "displayName": {
          "const": "Agent Apple Foundation Handoff"
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source", "policy", "category"],
        "properties": {
          "name": {
            "const": "apple-foundation-models-handoff"
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "path"],
            "properties": {
              "source": {
                "const": "local"
              },
              "path": {
                "const": "./plugins/apple-foundation-models-handoff"
              }
            }
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["installation", "authentication"],
            "properties": {
              "installation": {
                "const": "AVAILABLE"
              },
              "authentication": {
                "const": "ON_INSTALL"
              }
            }
          },
          "category": {
            "const": "Developer Tools"
          }
        }
      }
    }
  }
}
